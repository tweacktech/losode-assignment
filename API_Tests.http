################################################################################
# AUTHENTICATION - VENDOR
################################################################################

### 1. Register Vendor
POST {{baseUrl}}/vendor/register
Content-Type: application/json

{
  "name": "Test Vendor",
  "email": "test.vendor@example.com",
  "password": "password123",
  "business_name": "Test Business",
  "phone": "+234900000000"
}

###

### 2. Login Vendor
POST {{baseUrl}}/vendor/login
Content-Type: application/json

{
  "email": "test.vendor@example.com",
  "password": "password123"
}

###

### 3. Get Vendor Profile (Protected)
GET {{baseUrl}}/vendor/me
Authorization: Bearer {{vendorToken}}

###

### 4. Logout Vendor (Protected)
POST {{baseUrl}}/vendor/logout
Authorization: Bearer {{vendorToken}}

###

################################################################################
# AUTHENTICATION - CUSTOMER/USER
################################################################################

### 5. Register Customer
POST {{baseUrl}}/users/register
Content-Type: application/json

{
  "name": "Test Customer",
  "email": "test.customerh@example.com",
  "password": "password123",
  "phone": "+234901000000",
  "address": "123 Main Street",
  "city": "Lagos",
  "state": "Lagos",
  "postal_code": "100001"
}

###

### 6. Login Customer
POST {{baseUrl}}/users/login
Content-Type: application/json

{
  "email": "test.customerh@example.com",
  "password": "password123"
}

###

### 7. Get Customer Profile (Protected)
GET {{baseUrl}}/users/me
Authorization: Bearer {{customerToken}}

###

### 8. Update Customer Profile (Protected)
PUT {{baseUrl}}/users/profile
Authorization: Bearer {{customerToken}}
Content-Type: application/json

{
  "name": "Updated Name",
  "phone": "+234902000000",
  "address": "456 Oak Avenue",
  "city": "Ibadan"
}

###

### 9. Get Customer Statistics (Protected)
GET {{baseUrl}}/users/stats
Authorization: Bearer {{customerToken}}

###

### 10. Logout Customer (Protected)
POST {{baseUrl}}/users/logout
Authorization: Bearer {{customerToken}}

###

### 11. Deactivate Customer Account (Protected)
DELETE {{baseUrl}}/users/account
Authorization: Bearer {{customerToken}}

###

